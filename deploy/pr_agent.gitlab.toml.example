# Fill in your REAL cloud GitLab + a bot token + a webhook secret.
[config]
model = "openai/reviewer"   # stable alias; the real model lives in config.yaml
fallback_models = []
custom_model_max_tokens = 200000   # set near your model's context window. Spend still capped by LiteLLM max_budget + provider console.
git_provider = "gitlab"
publish_output = true
response_language = "zh-TW"   # 預設輸出語言；改成 "en-US" 用英文，"zh-CN" 用簡中

[openai]
api_base = "http://cqb-litellm:4000"
key = "sk-cqb-________"                 # MUST equal LITELLM_MASTER_KEY in .env

[gitlab]
url = "https://gitlab.com"              # or your cloud self-managed GitLab base URL
personal_access_token = "glpat-________"  # a bot/group token, scope: api
shared_secret = "________"              # random; must match the GitLab webhook 'Secret token'
