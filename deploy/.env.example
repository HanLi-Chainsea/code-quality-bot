# Fill the key for whichever model you point `reviewer` at in config.yaml.
LITELLM_MASTER_KEY=sk-cqb-________        # any random string; must match pr_agent.gitlab.toml [openai] key

# --- pick ONE provider (the one `reviewer` points to). Leave the rest blank. ---
MINIMAX_API_KEY=sk-cp-________            # current
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
# (local Ollama/vLLM need no key)

# --- optional reviewer-local FALLBACK (config.yaml `reviewer-local`): key for the local server ---
# CQB_REVIEWER_API_KEY=claw                # whatever your local MLX/Ollama/vLLM server expects

# --- engine VERIFY backend (review_engine.Client) — points the in-container verify at a model.
#     Set on the pr-agent service in docker-compose; here for reference. Local MLX example: ---
# REVIEWER_BASE_URL=http://host.docker.internal:31968/v1
# REVIEWER_MODEL=<served-model>
# REVIEWER_EXTRA_BODY={"response_format":{"type":"json_object"}}
